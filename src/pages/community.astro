---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
---

<BaseLayout title="Community" description="Join the Nehal-aditya and Deepcomet AI community — connect on GitHub, YouTube, and more.">

  <HeroSection
    subtitle="Community"
    title='Join Our <span class="glow-text">Community</span>'
    description="Connect with us on our social channels and forums. We'd love to have you as part of our growing community of developers, researchers, and tech enthusiasts."
  />

  <section class="section">
    <div class="container">
      <div class="grid-2 stagger-children">
        <a href="https://github.com/Nehal-aditya" target="_blank" rel="noopener" class="card community-card">
          <div class="community-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <h3>GitHub</h3>
          <p>Explore our open-source projects, contribute code, file issues, and collaborate with other developers.</p>
          <span class="community-link">github.com/Nehal-aditya &rarr;</span>
        </a>

        <a href="https://www.youtube.com/@Bright-Hypothesis" target="_blank" rel="noopener" class="card community-card">
          <div class="community-icon youtube">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </div>
          <h3>YouTube</h3>
          <p>Watch tutorials, project demos, tech talks, and science content on our Bright Hypothesis channel.</p>
          <span class="community-link">@Bright-Hypothesis &rarr;</span>
        </a>

        <a href="https://github.com/deepcometai" target="_blank" rel="noopener" class="card community-card">
          <div class="community-icon deepcomet">
            <span style="font-size: 2.5rem;">&#9670;</span>
          </div>
          <h3>Deepcomet AI</h3>
          <p>Explore the Deepcomet AI organization — our ecosystem of AI-native technologies and futuristic computing projects.</p>
          <span class="community-link">github.com/deepcometai &rarr;</span>
        </a>

        <div class="card community-card email-card">
          <div class="community-icon email">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <h3>Email Us</h3>
          <p>Want to join our community or have questions? Reach out to us directly via email.</p>
          <a href="mailto:nehaladityaresearch@gmail.com" class="community-link">nehaladityaresearch@gmail.com &rarr;</a>
        </div>
      </div>

      <div class="divider"></div>

      <div class="join-section reveal">
        <h2>How to <span class="glow-text">Get Involved</span></h2>
        <div class="grid-3 stagger-children">
          <div class="card">
            <h3>Contribute Code</h3>
            <p>Fork our repositories, submit pull requests, and help improve our open-source projects. Every contribution matters.</p>
          </div>
          <div class="card">
            <h3>Report Issues</h3>
            <p>Found a bug or have a feature request? Open an issue on GitHub and help us make our projects better.</p>
          </div>
          <div class="card">
            <h3>Share Knowledge</h3>
            <p>Write blog posts, create tutorials, or help answer questions. Sharing knowledge strengthens the entire community.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .community-card {
    text-decoration: none;
    color: inherit;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .community-card:hover {
    color: inherit;
  }

  .community-icon {
    color: var(--neon-cyan);
    margin-bottom: 1.25rem;
    filter: drop-shadow(0 0 10px rgba(0, 240, 255, 0.3));
  }

  .community-icon.youtube {
    color: #ff0000;
    filter: drop-shadow(0 0 10px rgba(255, 0, 0, 0.3));
  }

  .community-icon.deepcomet {
    color: var(--neon-purple);
    filter: drop-shadow(0 0 10px rgba(168, 85, 247, 0.3));
  }

  .community-icon.email {
    color: var(--neon-green);
    filter: drop-shadow(0 0 10px rgba(34, 211, 238, 0.3));
  }

  .community-link {
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--neon-cyan);
  }

  .email-card {
    cursor: default;
  }

  .join-section {
    text-align: center;
  }

  .join-section h2 {
    margin-bottom: 2rem;
  }
</style>
