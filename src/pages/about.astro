---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import Accordion from '../components/Accordion.astro';

const faqItems = [
  {
    title: 'What is Deepcomet AI?',
    content: 'Deepcomet AI is a visionary, friend-driven, ecosystem-oriented institution focused on vertical AI integration and futuristic computing. We are building a complete AI stack — from programming languages to operating systems — designed for a world where AI is not an afterthought but the core.',
  },
  {
    title: 'What technologies does Nehal-aditya work with?',
    content: 'Our stack spans web development (React, Next.js, Nuxt.js, Astro), systems programming (Rust, C++, .NET), AI/ML research, and low-level OS development. We are especially focused on building <strong>Aurelia</strong>, an AI-native language, and <strong>SkyOS</strong>, a generative operating system.',
  },
  {
    title: 'How can I contribute?',
    content: 'Check out our <a href="https://github.com/Nehal-aditya">GitHub</a> for open-source projects. You can also join the community by emailing <strong>nehaladityaresearch@gmail.com</strong> or visiting the <a href="/community/">Community</a> page.',
  },
  {
    title: 'What is the Deepcomet AI ecosystem?',
    content: 'The Deepcomet AI ecosystem is a vertically integrated AI stack comprising four core components: <strong>Aurelia</strong> (AI-native programming language with first-class tensors and MLIR compilation), <strong>Zenith Kernel</strong> (microkernel with probabilistic scheduling and AI-Watchdog security), <strong>SkyOS</strong> (generative OS powered by Large Action Models), and <strong>The Forge</strong> (automated legacy code migration tooling). Together they form a complete AI-first computing platform.',
  },
];
---

<BaseLayout title="About" description="Learn about Nehal-aditya and the Deepcomet AI vision for futuristic computing.">

  <HeroSection
    subtitle="About"
    title={'Hi, I\'m <span class="glow-text">Nehal-aditya</span>'}
    description="Passionate about web development, curious about science concepts, and always learning new things. Building the future with Deepcomet AI."
  />

  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-main">
          <h2>My Story</h2>
          <p>I'm Nehal-aditya, and this is my personal space on the web. I'm passionate about web development and curious about science concepts, always learning new things.</p>
          <p>As part of the <strong>Deepcomet AI</strong> ecosystem, I work at the intersection of AI research, systems programming, and futuristic computing. Our mission is to build a vertically integrated AI stack — from the Aurelia programming language to the SkyOS generative operating system — that redefines how humans interact with intelligent systems.</p>
          <p>This site serves as the hub for our brands, software, projects, and updates. It reflects our commitment to pushing boundaries in technology and building tools that empower the next generation of developers and researchers.</p>

          <div class="divider"></div>

          <h2>Vision &amp; Mission</h2>
          <p>Deepcomet AI is not just an organization — it is a <strong>friend-driven, ecosystem-oriented institution</strong> built on shared passion and collective ambition. Our vision encompasses:</p>
          <ul>
            <li><strong>Vertical AI Integration</strong> — Building every layer of the AI stack, from hardware interfaces to user-facing applications.</li>
            <li><strong>Open Innovation</strong> — Sharing our research, tools, and knowledge with the global developer community.</li>
            <li><strong>Accessible Technology</strong> — Making advanced computing concepts approachable and usable for everyone.</li>
            <li><strong>Futuristic Computing</strong> — Pioneering new paradigms in operating systems, programming languages, and AI infrastructure.</li>
          </ul>

          <div class="divider"></div>

          <h2>Frequently Asked Questions</h2>
          <Accordion items={faqItems} />
        </div>

        <aside class="about-sidebar">
          <div class="card sidebar-card">
            <h3>Quick Links</h3>
            <ul class="sidebar-links">
              <li><a href="/projects/">Projects</a></li>
              <li><a href="/ecosystem/">Ecosystem</a></li>
              <li><a href="/blog/">Blog</a></li>
              <li><a href="/docs/">Documentation</a></li>
              <li><a href="/community/">Community</a></li>
            </ul>
          </div>

          <div class="card sidebar-card">
            <h3>Organization</h3>
            <p><strong>Deepcomet AI</strong></p>
            <p class="sidebar-desc">A visionary institution focused on vertical AI integration and futuristic computing.</p>
            <a href="https://deepcometai.github.io" target="_blank" rel="noopener" class="btn btn-outline btn-sm" style="margin-top: 0.75rem;">Visit Deepcomet AI &rarr;</a>
          </div>

          <div class="card sidebar-card">
            <h3>Tech Stack</h3>
            <div class="tag-cloud">
              <span class="tag">Astro</span>
              <span class="tag">React</span>
              <span class="tag">Next.js</span>
              <span class="tag">Nuxt.js</span>
              <span class="tag">Rust</span>
              <span class="tag">C++</span>
              <span class="tag">Python</span>
              <span class="tag">.NET</span>
              <span class="tag">MLIR</span>
              <span class="tag">Aurelia</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }

  .about-main h2 {
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .about-main p {
    line-height: 1.8;
  }

  .about-main ul {
    padding-left: 1.5rem;
    margin: 1rem 0 1.5rem;
    color: var(--text-secondary);
  }

  .about-main li {
    margin-bottom: 0.75rem;
    line-height: 1.7;
  }

  .sidebar-card {
    margin-bottom: 1.5rem;
  }

  .sidebar-card h3 {
    font-size: 1rem;
    margin-bottom: 1rem;
  }

  .sidebar-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-links li {
    margin-bottom: 0.5rem;
  }

  .sidebar-links a {
    color: var(--text-secondary);
    font-size: 0.9rem;
    transition: color var(--transition-fast);
  }

  .sidebar-links a:hover {
    color: var(--neon-cyan);
  }

  .sidebar-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25em 0.7em;
    background: rgba(0, 240, 255, 0.06);
    border: 1px solid rgba(0, 240, 255, 0.15);
    border-radius: 6px;
    color: var(--neon-cyan);
    font-family: var(--font-mono);
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    display: inline-flex;
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-sidebar {
      order: -1;
    }
  }
</style>
