---
interface Props {
  title: string;
  description: string;
  tags: string[];
  href?: string;
  repo?: string;
}

const { title, description, tags, href, repo } = Astro.props;
---

<div class="project-card card">
  <h3>{title}</h3>
  <p>{description}</p>
  <div class="project-tags">
    {tags.map(tag => (
      <span class="tag">{tag}</span>
    ))}
  </div>
  <div class="project-links">
    {href && <a href={href} class="btn btn-outline btn-sm">Learn More &rarr;</a>}
    {repo && <a href={repo} target="_blank" rel="noopener" class="btn btn-outline btn-sm">GitHub &rarr;</a>}
  </div>
</div>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
  }

  .project-card h3 {
    margin-bottom: 0.75rem;
  }

  .project-card p {
    flex: 1;
    margin-bottom: 1.25rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25em 0.7em;
    background: rgba(0, 240, 255, 0.06);
    border: 1px solid rgba(0, 240, 255, 0.15);
    border-radius: 6px;
    color: var(--neon-cyan);
    font-family: var(--font-mono);
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
  }
</style>
